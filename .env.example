# Personal quickstart defaults. Copy to .env and edit.

WORKSPACE_DIR=/workspace

HF_HOME=/workspace/hf-cache
HUGGINGFACE_HUB_CACHE=/workspace/hf-cache/hub
HF_HUB_CACHE=/workspace/hf-cache/hub
TRANSFORMERS_CACHE=/workspace/hf-cache/transformers
VLLM_CACHE_ROOT=/workspace/vllm-cache
TMPDIR=/workspace/tmp

CUDA_HOME=/usr/local/cuda
MAX_JOBS=64
NVCC_THREADS=64
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
CUDA_VISIBLE_DEVICES=0

SERVE_MODEL=AEON-7/Gemma-4-26B-A4B-it-Uncensored-NVFP4
SERVE_HOST=127.0.0.1
SERVE_PORT=8000
SERVE_DTYPE=bfloat16
SERVE_KV_CACHE_DTYPE=fp8
SERVE_GPU_MEMORY_FRACTION=0.90
SERVE_CONTEXT_LENGTH=256K
SERVE_BATCHED_TOKENS=32768
SERVE_MM_LIMIT='{"image":4,"video":1}'
SERVE_API_KEY=sk-test

TOOLS_HOST=127.0.0.1
TOOLS_PORT=17071
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=sk-test
TOOL_SERVER_CONNECTIONS='[{"url": "http://127.0.0.1:17071", "path": "/openapi.json", "type": "openapi", "auth_type": "none", "headers": {}, "key": "", "config": {"enable": true}, "info": {"id": "web_image_tools", "name": "Web + Image + Video Tools", "description": "Web search, image search, image inspection, and direct video URL inspection via local vLLM"}}]'

OPEN_WEBUI_HOST=127.0.0.1
OPEN_WEBUI_PORT=3000
OPEN_WEBUI_DATA_DIR=/workspace/open-webui-data
OPENAI_API_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=sk-test
