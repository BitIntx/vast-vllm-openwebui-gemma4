# Personal quickstart defaults. Copy to .env and edit.

WORKSPACE_DIR=/workspace

HF_HOME=/workspace/hf-cache
HUGGINGFACE_HUB_CACHE=/workspace/hf-cache/hub
HF_HUB_CACHE=/workspace/hf-cache/hub
TRANSFORMERS_CACHE=/workspace/hf-cache/transformers
VLLM_CACHE_ROOT=/workspace/vllm-cache
TMPDIR=/workspace/tmp

CUDA_HOME=/usr/local/cuda
MAX_JOBS=64
NVCC_THREADS=64
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
CUDA_VISIBLE_DEVICES=0

SERVE_MODEL=AEON-7/Gemma-4-26B-A4B-it-Uncensored-NVFP4
SERVE_HOST=127.0.0.1
SERVE_PORT=8000
SERVE_DTYPE=bfloat16
SERVE_KV_CACHE_DTYPE=fp8
SERVE_GPU_MEMORY_FRACTION=0.90
SERVE_CONTEXT_LENGTH=256K
SERVE_BATCHED_TOKENS=32768
SERVE_MM_LIMIT='{"image":8,"video":1}'
SERVE_API_KEY=sk-test

TOOLS_HOST=127.0.0.1
TOOLS_PORT=17071

# Tool inspection backend. Web search/page/image-search tools do not require either backend.
# inspect_image uses Ollama vision by default.
# inspect_image_deep sends overview + zoomed crop tiles to Ollama vision.
# ocr_image uses EasyOCR locally.
# inspect_video samples frames with ffmpeg and sends them to Ollama vision.
TOOL_BACKEND=ollama
ENABLE_INSPECT_TOOLS=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_INSPECT_MODEL=
OLLAMA_INSPECT_ENABLE_THINKING=true
OLLAMA_INSPECT_RETURN_THINKING=false
OLLAMA_INSPECT_RETRY_WITHOUT_THINKING=true
OLLAMA_INSPECT_KEEP_ALIVE=1h
OLLAMA_INSPECT_MAX_IMAGE_MB=50
OLLAMA_INSPECT_MAX_VIDEO_MB=200
OLLAMA_INSPECT_MAX_IMAGE_SIDE=2048
OLLAMA_IMAGE_TIMEOUT_SECONDS=600
OLLAMA_IMAGE_DEEP_TIMEOUT_SECONDS=900
OLLAMA_VIDEO_TIMEOUT_SECONDS=900
OPENWEBUI_TOOLS_MAX_PDF_MB=100
OPENWEBUI_CHROME_PATH=
OPENWEBUI_CHROME_LIBRARY_PATH=
OPENWEBUI_CHROME_RUNTIME_ROOT=

# vLLM settings are still used by the vLLM server scripts and older deployments.
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=sk-test
TOOL_SERVER_CONNECTIONS='[{"url": "http://127.0.0.1:17071", "path": "/openapi.json", "type": "openapi", "auth_type": "none", "headers": {}, "key": "", "config": {"enable": true}, "info": {"id": "web_image_tools", "name": "Web + Image + Video Tools", "description": "Web search, webpage reading, image search, media URL resolution, and image/video inspection via local Ollama vision or vLLM setup"}}]'

LOCAL_MEDIA_HOST=127.0.0.1
LOCAL_MEDIA_PORT=9000
LOCAL_MEDIA_DIR=/workspace/media

OPEN_WEBUI_HOST=127.0.0.1
OPEN_WEBUI_PORT=3000
OPEN_WEBUI_DATA_DIR=/workspace/open-webui-data
OPENAI_API_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=sk-test
